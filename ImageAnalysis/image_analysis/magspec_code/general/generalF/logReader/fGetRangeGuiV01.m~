function rng = fGetRangeGuiV01(fName,nmb)%% get range of the data from Giullaume's level file%% rng = fGetRangeGuiV01(fName,nmb)%% fName: file name (full path)% nmb:  number of line (5 for density range)% rng:  array 1:min, 2:max%% Function fGetRangeGuiV01.m % get range from Guillaume file, ver.1% Kei Nakamura% Created on Friday, february 18th 2011.% Modified on %% ver.1: created%% main bodylin = fGetTextLineV01(fName,nmb)fid = fopen(fName);     % file open('name','permission')   for i=1:nmb              % density info in 5th line    lin = fgetl(fid);endfclose(fid);k = find(double(lin)==9);    % find tubrng(2) = str2double(lin(k(1)+1:k(2)-1));rng(1) = str2double(lin(k(2)+1:end));
