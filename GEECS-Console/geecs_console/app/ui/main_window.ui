<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ConsoleRoot</class>
 <widget class="QWidget" name="ConsoleRoot">
  <property name="windowTitle">
   <string>GEECS Console</string>
  </property>
  <layout class="QVBoxLayout" name="root_layout">
   <!-- R1: session bar -->
   <item>
    <layout class="QHBoxLayout" name="r1_session_bar">
     <item>
      <widget class="QLabel" name="r1_experiment_label">
       <property name="text">
        <string>Experiment</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="r1_experiment_combo">
       <property name="editable">
        <bool>true</bool>
       </property>
       <property name="minimumWidth">
        <number>140</number>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QLabel" name="r1_rep_rate_label">
       <property name="text">
        <string>Rep rate (Hz)</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QDoubleSpinBox" name="r1_rep_rate">
       <property name="decimals">
        <number>2</number>
       </property>
       <property name="minimum">
        <double>0.010000000000000</double>
       </property>
       <property name="maximum">
        <double>10000.000000000000000</double>
       </property>
       <property name="value">
        <double>1.000000000000000</double>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QLabel" name="r1_trigger_label">
       <property name="text">
        <string>Trigger profile</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="r1_trigger_profile_combo">
       <property name="minimumWidth">
        <number>140</number>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QComboBox" name="r1_trigger_variant_combo">
       <property name="minimumWidth">
        <number>100</number>
       </property>
       <property name="toolTip">
        <string>Trigger-profile variant (base behaviour when empty)</string>
       </property>
      </widget>
     </item>
     <item>
      <spacer name="r1_spacer">
       <property name="orientation">
        <enum>Qt::Horizontal</enum>
       </property>
       <property name="sizeHint" stdset="0">
        <size>
         <width>40</width>
         <height>20</height>
        </size>
       </property>
      </spacer>
     </item>
     <item>
      <widget class="QLabel" name="r1_gateway_chip">
       <property name="text">
        <string>gateway: unknown</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QLabel" name="r1_tiled_chip">
       <property name="text">
        <string>tiled: unknown</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QLabel" name="r1_db_chip">
       <property name="text">
        <string>db: unknown</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <!-- Three columns: R2 | R3+R4+R5 | R6+R7 -->
   <item>
    <layout class="QHBoxLayout" name="columns_layout">
     <!-- R2: save sets -->
     <item>
      <widget class="QGroupBox" name="r2_group">
       <property name="title">
        <string>Save sets</string>
       </property>
       <layout class="QVBoxLayout" name="r2_layout">
        <item>
         <layout class="QHBoxLayout" name="r2_lists_layout">
          <item>
